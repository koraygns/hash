<Window x:Class="hashadli.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ayarlar" Height="600" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#4A90E2" CornerRadius="5" Padding="15" Margin="0,0,0,20">
            <TextBlock Text="Hash Algoritması Ayarları" FontSize="20" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- Hash Seçimleri -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border BorderBrush="#DDD" BorderThickness="1" 
                        Background="White" CornerRadius="5" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Hesaplanacak Hash Algoritmalarını Seçin:" 
                                   FontWeight="SemiBold" FontSize="14" Margin="0,0,0,15"/>
                        
                        <CheckBox x:Name="chkMD5" Content="MD5" IsChecked="True" Margin="0,0,0,10" FontSize="13"/>
                        <CheckBox x:Name="chkSHA1" Content="SHA1" IsChecked="True" Margin="0,0,0,10" FontSize="13"/>
                        
                        <TextBlock Text="Not: En az bir hash algoritması seçilmelidir." 
                                   FontStyle="Italic" Foreground="#666" Margin="0,15,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- PDF Ayarları -->
                <Border BorderBrush="#DDD" BorderThickness="1" 
                        Background="White" CornerRadius="5" Padding="20">
                    <StackPanel>
                        <TextBlock Text="PDF Çıktı Ayarları:" 
                                   FontWeight="SemiBold" FontSize="14" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="Başlık (Zorunlu):" 
                                   FontWeight="SemiBold" FontSize="12" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtPdfTitle" Margin="0,0,0,15" FontSize="13" Padding="8"/>
                        
                        <TextBlock Text="Dosya Numarası:" 
                                   FontWeight="SemiBold" FontSize="12" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtPdfFileNumber" Margin="0,0,0,15" FontSize="13" Padding="8"/>
                        
                        <TextBlock Text="Kurum:" 
                                   FontWeight="SemiBold" FontSize="12" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtPdfOrganization" Margin="0,0,0,15" FontSize="13" Padding="8"/>
                        
                        <CheckBox x:Name="chkPdfShowDateTime" Content="PDF'de tarih saat göster" IsChecked="True" FontSize="13"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Butonlar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="İptal" Click="BtnCancel_Click" Width="100" Margin="0,0,10,0" 
                    Background="#CCCCCC" Foreground="Black"/>
            <Button Content="Kaydet" Click="BtnSave_Click" Width="100" Background="#50C878"/>
        </StackPanel>
    </Grid>
</Window>
