<Window x:Class="hashadli.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:hashadli"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:controls="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="webdedik › Hash" Height="700" Width="1000"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        Icon="pack://application:,,,/app_icon.ico"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        Drop="Window_Drop">
    <Window.Resources>
        <!-- BooleanToVisibilityConverter -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <Style TargetType="Button">
            <Setter Property="Background" Value="#4A90E2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#357ABD"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                    <Setter Property="Foreground" Value="#666666"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Profesyonel ScrollViewer Teması -->
        <Style TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Resources>
                <Style TargetType="ScrollBar">
                    <Setter Property="Background" Value="#F0F0F0"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Width" Value="14"/>
                    <Setter Property="MinWidth" Value="14"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid x:Name="GridRoot" Background="{TemplateBinding Background}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition MaxHeight="18"/>
                                        <RowDefinition Height="0.00001*"/>
                                        <RowDefinition MaxHeight="18"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="1" Background="#E0E0E0" CornerRadius="7" Margin="2,0"/>
                                    <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="True" Focusable="False">
                                        <Track.Thumb>
                                            <Thumb>
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border Background="#B0B0B0" CornerRadius="7" Margin="2,0"
                                                                BorderThickness="0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="#909090"/>
                                                                        </Trigger>
                                                                        <DataTrigger Binding="{Binding IsDragging, RelativeSource={RelativeSource AncestorType=Thumb}}" Value="True">
                                                                            <Setter Property="Background" Value="#707070"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
        </Style>

        <!-- DataGrid ScrollBar Özel Teması -->
        <Style x:Key="DataGridScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="16"/>
            <Setter Property="MinWidth" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="GridRoot" Background="{TemplateBinding Background}">
                            <Grid.RowDefinitions>
                                <RowDefinition MaxHeight="18"/>
                                <RowDefinition Height="0.00001*"/>
                                <RowDefinition MaxHeight="18"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="1" Background="#E8E8E8" CornerRadius="8" Margin="3,0"/>
                            <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="True" Focusable="False">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#C0C0C0" CornerRadius="8" Margin="3,2"
                                                        BorderThickness="0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#A0A0A0"/>
                                                                </Trigger>
                                                                <DataTrigger Binding="{Binding IsDragging, RelativeSource={RelativeSource AncestorType=Thumb}}" Value="True">
                                                                    <Setter Property="Background" Value="#808080"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                </Border>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern TabControl Teması -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- Modern TabItem Teması -->
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" Background="#E8E8E8" BorderThickness="0" CornerRadius="8,8,0,0" 
                                Margin="2,0,2,0" Padding="20,12">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center"
                                            ContentSource="Header" Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#4A90E2"/>
                                <Setter TargetName="ContentSite" Property="TextElement.Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="False"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Border" Property="Background" Value="#D0D0D0"/>
                                <Setter TargetName="ContentSite" Property="TextElement.Foreground" Value="#333333"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="False"/>
                                    <Condition Property="IsMouseOver" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Border" Property="Background" Value="#E8E8E8"/>
                                <Setter TargetName="ContentSite" Property="TextElement.Foreground" Value="#333333"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Margin" Value="2,0,2,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header - Sabit, her zaman görünür -->
        <Border Grid.Row="0" Background="#4A90E2" CornerRadius="0" Padding="20" Margin="0" x:Name="headerBorder"
                BorderThickness="0,0,0,2" BorderBrush="#357ABD">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Hash Hesaplayıcı" FontSize="28" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" x:Name="txtHeader"/>
                        <Button Grid.Column="1" Content="❓ Yardım" Click="BtnHelp_Click" 
                            Background="#357ABD" Foreground="White" Padding="15,8" Margin="0,0,10,0"
                            FontSize="13" FontWeight="SemiBold" Cursor="Hand"/>
                        <Button Grid.Column="2" Content="⚙ Ayarlar" Click="BtnSettings_Click" 
                            Background="#357ABD" Foreground="White" Padding="15,8" 
                            FontSize="13" FontWeight="SemiBold" Cursor="Hand"/>
                    </Grid>
        </Border>
        
            <!-- Tab Control - ScrollViewer kaldırıldı, her TabItem kendi ScrollViewer'ını kullanacak -->
        <TabControl Grid.Row="1" Margin="20,10,20,20" BorderThickness="0" x:Name="mainTabControl" SelectionChanged="MainTabControl_SelectionChanged">
                    <TabItem Header="Dosya Hash Hesaplama">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Üst Kontroller - ScrollViewer içinde -->
                            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                          Style="{StaticResource {x:Type ScrollViewer}}"
                                          PanningMode="VerticalOnly">
                                <StackPanel>
                                    <!-- Dosya Listesi Başlık ve Ekle Butonu -->
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Dosyalar:" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="+ Dosya Ekle" Click="BtnAddFile_Click" 
                                        Background="#50C878" Foreground="White" Width="120" Padding="10,5" MinWidth="120"/>
                                    </Grid>

                                    <!-- Dosya Listesi -->
                                    <Border BorderBrush="#DDD" BorderThickness="1" 
                                    Background="White" CornerRadius="5" Padding="10" Margin="0,0,0,15">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                              Style="{StaticResource {x:Type ScrollViewer}}"
                                              MaxHeight="250">
                                            <ItemsControl x:Name="fileListItemsControl" Loaded="FileListItemsControl_Loaded">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,0,0,10" BorderThickness="1" BorderBrush="#DDD" Padding="12" 
                                                        Background="{Binding BackgroundColor}" CornerRadius="5">
                                                            <Grid Margin="0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" MinWidth="90"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>
                                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Top" 
                                                                          TextTrimming="CharacterEllipsis" MinWidth="90" Margin="0,0,12,0"
                                                                          FontWeight="SemiBold" FontSize="13"/>
                                                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding FilePath}" 
                                                                         TextWrapping="Wrap" 
                                                                         VerticalAlignment="Top" Margin="0,0,12,0"
                                                                         FontSize="12" Foreground="#555"/>
                                                                <Button Grid.Row="0" Grid.Column="2" Content="Seç" Click="BtnSelectFile_Click" 
                                                                Width="90" MinWidth="85" Height="32" Margin="0,0,8,0" Tag="{Binding}"
                                                                Background="#4A90E2" Foreground="White" FontWeight="SemiBold"
                                                                Cursor="Hand" VerticalAlignment="Center" Padding="10,0"/>
                                                                <Button Grid.Row="0" Grid.Column="3" Content="✕" Click="BtnRemoveFile_Click" 
                                                                Width="40" Height="32" Background="#FF6B6B" Foreground="White"
                                                                FontSize="14" FontWeight="Bold" Padding="0" Tag="{Binding}"
                                                                Cursor="Hand" VerticalAlignment="Top"
                                                                Visibility="{Binding CanRemove, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>

                                    <!-- Hash Hesapla Button -->
                                    <Button Content="Hash Hesapla" Click="BtnCalculateFileHash_Click" 
                                    Margin="0,0,0,15" Background="#50C878" Foreground="White" 
                                    FontSize="14" FontWeight="SemiBold" x:Name="btnCalculateFileHash" 
                                    HorizontalAlignment="Stretch" Padding="10,8" MinHeight="40"/>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Results -->
                            <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="1" 
                            Background="White" CornerRadius="5" Padding="15" x:Name="hashResultsBorder">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <!-- Toplu PDF Çıkar Butonu - Sadece birden fazla sonuç varsa görünür -->
                                    <Button x:Name="btnExportAllToPdf" 
                                            Grid.Row="0"
                                            Content="💾 Toplu PDF Çıkar" 
                                            Click="BtnExportAllToPdf_Click" 
                                            Width="150" 
                                            Height="35" 
                                            Margin="0,0,0,10"
                                            Background="#4A90E2" 
                                            Foreground="White"
                                            FontSize="13" 
                                            FontWeight="SemiBold"
                                            HorizontalAlignment="Right"
                                            Visibility="Collapsed"/>
                                    <ScrollViewer Grid.Row="1" 
                                          VerticalScrollBarVisibility="Auto" 
                                          HorizontalScrollBarVisibility="Auto"
                                          Style="{StaticResource {x:Type ScrollViewer}}" 
                                          x:Name="hashResultsScrollViewer">
                                        <ItemsControl x:Name="hashResultsItemsControl">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" 
                                                Padding="10" Margin="0,0,0,10" Background="#F9F9F9">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding FileName}" 
                                                          FontWeight="Bold" FontSize="14" Margin="0,0,10,8"
                                                          TextWrapping="Wrap" VerticalAlignment="Top"/>
                                                        <Button Grid.Row="0" Grid.Column="1" Content="💾 PDF" Click="BtnSaveAsPdf_Click" 
                                                        Width="75" Height="32" Background="#4A90E2" Foreground="White"
                                                        FontSize="11" FontWeight="SemiBold" Margin="0,0,5,8" Tag="{Binding}"
                                                        VerticalAlignment="Top"/>
                                                        <Button Grid.Row="0" Grid.Column="2" Content="✕" Click="BtnRemoveResult_Click" 
                                                        Width="35" Height="32" Background="#FF6B6B" Foreground="White"
                                                        FontSize="12" FontWeight="Bold" Padding="0" Margin="0,0,0,8" Tag="{Binding}"
                                                        VerticalAlignment="Top"/>
                                                        <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" 
                                                         Text="{Binding HashResult, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" 
                                                         Background="White" BorderThickness="0" Padding="8"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Klasör Hash Hesaplama">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Üst Kontroller - ScrollViewer içinde -->
                            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                          Style="{StaticResource {x:Type ScrollViewer}}"
                                          PanningMode="VerticalOnly"
                                          MaxHeight="200">
                                <StackPanel>
                                    <!-- Klasör Seç -->
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Klasör:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBox Grid.Column="1" x:Name="txtFolder" IsReadOnly="True" Margin="0,0,10,0"/>
                                        <Button Grid.Column="2" Content="Klasör Seç" Click="BtnSelectFolder_Click" Width="100"/>
                                    </Grid>

                                    <!-- İşlem Butonları -->
                                    <Button x:Name="btnCalculateFolderHash" Content="Hash Hesapla" Click="BtnCalculateFolderHash_Click" 
                                    Margin="0,0,0,15" HorizontalAlignment="Stretch" Background="#50C878"/>

                                    <!-- Arama ve Sıfırla -->
                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Ara:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBox Grid.Column="1" x:Name="txtSearch" TextChanged="TxtSearch_TextChanged" 
                                         Margin="0,0,10,0" Padding="8"/>
                                        <Button Grid.Column="2" Content="Temizle" Click="BtnClearSearch_Click" 
                                        Width="80" Background="#CCCCCC" Foreground="Black" Margin="0,0,10,0"/>
                                        <Button Grid.Column="3" Content="🔄 Sıfırla" Click="BtnResetFilter_Click" 
                                        Width="100" Background="#FFA500" Foreground="White"/>
                                    </Grid>
                                    
                                    <!-- Renk Açıklamaları -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                        <Border Background="#C8DCFF" CornerRadius="3" Padding="8,4" Margin="0,0,15,0">
                                            <TextBlock FontSize="11" Foreground="#333">
                                                <Run Text="■ " Foreground="#4A90E2" FontWeight="Bold"/>
                                                <Run Text="Mavi = Klasör"/>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Results List - DataGrid kendi ScrollViewer'ını kullanır, header'lar sticky olur -->
                            <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="1" 
                            Background="White" CornerRadius="5" Padding="10" x:Name="borderResults">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Button Grid.Row="0" Content="💾 PDF Olarak Dışa Aktar" Click="BtnExportFolderResultsToPdf_Click" 
                                    HorizontalAlignment="Right" Margin="0,0,0,10" Background="#4A90E2" 
                                    Foreground="White" Padding="10,5" FontSize="12"/>
                                    <DataGrid Grid.Row="1" x:Name="dgResults" AutoGenerateColumns="False" 
                                      IsReadOnly="True" GridLinesVisibility="All" 
                                      HeadersVisibility="Column" CanUserResizeColumns="True"
                                      CanUserSortColumns="True" SelectionMode="Single"
                                      LoadingRow="DgResults_LoadingRow"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto"
                                      FrozenColumnCount="0"
                                      EnableColumnVirtualization="False"
                                      EnableRowVirtualization="True"
                                      CanUserReorderColumns="False"
                                      CanUserAddRows="False">
                                        <DataGrid.ColumnHeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#F0F0F0"/>
                                                <Setter Property="Foreground" Value="#333333"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="Padding" Value="8,5"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                                <Setter Property="BorderBrush" Value="#CCCCCC"/>
                                                <Setter Property="Height" Value="35"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                            </Style>
                                        </DataGrid.ColumnHeaderStyle>
                                        <DataGrid.Resources>
                                            <Style TargetType="ScrollBar" BasedOn="{StaticResource DataGridScrollBarStyle}"/>
                                            <!-- Text Wrapping için Style -->
                                            <Style TargetType="TextBlock" x:Key="DataGridTextBlockStyle">
                                                <Setter Property="TextWrapping" Value="Wrap"/>
                                                <Setter Property="TextTrimming" Value="None"/>
                                            </Style>
                                        </DataGrid.Resources>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Sıra" Binding="{Binding RowNumber}" Width="60" MinWidth="50" IsReadOnly="True" CanUserReorder="False">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Klasör Yolu" Binding="{Binding FolderPath}" Width="*" MinWidth="100">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Dosya Yolu" Binding="{Binding FilePath}" Width="*" MinWidth="100">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Dosya Adı" Binding="{Binding FileName}" Width="*" MinWidth="100">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Uzantı" Binding="{Binding FileExtension}" Width="80" MinWidth="60">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="MD5 Hash" Binding="{Binding MD5Hash}" Width="*" MinWidth="150" x:Name="colMD5">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="SHA1 Hash" Binding="{Binding SHA1Hash}" Width="*" MinWidth="150" x:Name="colSHA1">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="SHA256 Hash" Binding="{Binding SHA256Hash}" Width="*" MinWidth="200" x:Name="colSHA256">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="SHA384 Hash" Binding="{Binding SHA384Hash}" Width="*" MinWidth="200" x:Name="colSHA384">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="SHA512 Hash" Binding="{Binding SHA512Hash}" Width="*" MinWidth="200" x:Name="colSHA512">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Tarih" Binding="{Binding HashDate, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Width="150" MinWidth="120">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- İki Dosya Karşılaştırma -->
                    <TabItem Header="İki Dosya Karşılaştırma">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Dosya Seçim Alanı -->
                            <Grid Grid.Row="0" Margin="0,0,0,15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Dosya 1 -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Dosya 1:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtCompareFile1" IsReadOnly="True"
                                         Margin="0,0,10,0" TextWrapping="Wrap" VerticalContentAlignment="Center"/>
                                <Button Grid.Row="0" Grid.Column="2" Content="Seç" Click="BtnSelectCompareFile1_Click"
                                        Width="100" MinWidth="90" Height="32" Margin="0,0,0,0"
                                        Background="#4A90E2" Foreground="White"
                                        Padding="10,0" VerticalAlignment="Center"/>

                                <!-- Dosya 2 -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Dosya 2:" VerticalAlignment="Center" Margin="0,5,10,0"/>
                                <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtCompareFile2" IsReadOnly="True"
                                         Margin="0,5,10,0" TextWrapping="Wrap" VerticalContentAlignment="Center"/>
                                <Button Grid.Row="1" Grid.Column="2" Content="Seç" Click="BtnSelectCompareFile2_Click"
                                        Width="100" MinWidth="90" Height="32" Margin="0,5,0,0"
                                        Background="#4A90E2" Foreground="White"
                                        Padding="10,0" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Karşılaştır Butonu -->
                            <Button Grid.Row="1" Content="Karşılaştır" Click="BtnCompareFiles_Click"
                                    Margin="0,0,0,15" HorizontalAlignment="Stretch"
                                    Background="#FF6B6B" Foreground="White"
                                    FontSize="14" FontWeight="SemiBold"/>

                            <!-- Sonuçlar -->
                            <Border Grid.Row="2" BorderBrush="#DDD" BorderThickness="1"
                                    Background="White" CornerRadius="5" Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Özet + PDF butonu -->
                                    <Grid Grid.Row="0" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="txtFileCompareStatus"
                                                   Grid.Column="0"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="#333"
                                                   VerticalAlignment="Center"
                                                   Text="Karşılaştırma sonucu henüz yok."/>
                                        <Button Grid.Column="1"
                                                Content="💾 PDF Çıkar"
                                                Click="BtnExportFileCompareToPdf_Click"
                                                Width="140"
                                                Height="30"
                                                Margin="10,0,0,0"
                                                Background="#4A90E2"
                                                Foreground="White"
                                                FontSize="12"
                                                FontWeight="SemiBold"/>
                                    </Grid>

                                    <!-- Detaylı Karşılaştırma Tablosu -->
                                    <DataGrid Grid.Row="1"
                                              x:Name="dgFileCompareResults"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              GridLinesVisibility="All"
                                              HeadersVisibility="Column"
                                              CanUserResizeColumns="True"
                                              CanUserSortColumns="False"
                                              SelectionMode="Single"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Auto"
                                              LoadingRow="DgFileCompareResults_LoadingRow">
                                        <DataGrid.ColumnHeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="#F0F0F0"/>
                                                <Setter Property="Foreground" Value="#333333"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="Padding" Value="8,5"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                                <Setter Property="BorderBrush" Value="#CCCCCC"/>
                                                <Setter Property="Height" Value="35"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                            </Style>
                                        </DataGrid.ColumnHeaderStyle>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Sıra" Binding="{Binding RowNumber}" Width="60" IsReadOnly="True"/>
                                            <DataGridTextColumn Header="Özellik" Binding="{Binding PropertyName}" Width="120"/>
                                            <DataGridTextColumn Header="Dosya 1" Binding="{Binding File1Value}" Width="*">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Dosya 2" Binding="{Binding File2Value}" Width="*">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="Durum" Binding="{Binding ComparisonStatus}" Width="120"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="İki Klasör Karşılaştırma">
                        <Grid Margin="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Klasör 1 Seç -->
                            <Grid Grid.Row="0" Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Klasör 1:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBox Grid.Column="1" x:Name="txtFolder1" IsReadOnly="True" Margin="0,0,10,0"/>
                                <Button Grid.Column="2" Content="Klasör Seç" Click="BtnSelectFolder1_Click" Width="100"/>
                            </Grid>

                            <!-- Klasör 2 Seç -->
                            <Grid Grid.Row="1" Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Klasör 2:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBox Grid.Column="1" x:Name="txtFolder2" IsReadOnly="True" Margin="0,0,10,0"/>
                                <Button Grid.Column="2" Content="Klasör Seç" Click="BtnSelectFolder2_Click" Width="100"/>
                            </Grid>

                            <!-- Karşılaştır Butonu -->
                            <Button x:Name="btnCompareFolders" Grid.Row="2" Content="Karşılaştır" Click="BtnCompareFolders_Click" 
                            Margin="0,0,0,15" HorizontalAlignment="Stretch" Background="#FF6B6B"/>

                            <!-- Filtreleme Butonları ve Renk Açıklamaları -->
                            <StackPanel Grid.Row="3" Margin="0,0,0,15">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button Content="Tümü" Click="BtnFilterAllCompare_Click" Margin="0,0,10,0" Width="100" Background="#4A90E2"/>
                                    <Button Content="Aynı Olanlar" Click="BtnFilterSameCompare_Click" Margin="0,0,10,0" Width="120" Background="#50C878"/>
                                    <Button Content="Farklı Olanlar" Click="BtnFilterDifferentCompare_Click" Margin="0,0,10,0" Width="130" Background="#FF6B6B"/>
                                    <Button Content="Fazla Olanlar" Click="BtnFilterExtraCompare_Click" Margin="0,0,10,0" Width="140" Background="#FFD700" Foreground="#333"/>
                                    <Button Content="💾 PDF Çıkar" Click="BtnExportCompareToPdf_Click" Width="120" Background="#4A90E2" Foreground="White"/>
                                </StackPanel>
                                <!-- Renk Açıklamaları -->
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <Border Background="#C8DCFF" CornerRadius="3" Padding="8,4" Margin="0,0,15,0">
                                        <TextBlock FontSize="11" Foreground="#333">
                                            <Run Text="■ " Foreground="#4A90E2" FontWeight="Bold"/>
                                            <Run Text="Mavi = Klasör"/>
                                        </TextBlock>
                                    </Border>
                                    <Border Background="#C8FFC8" CornerRadius="3" Padding="8,4" Margin="0,0,15,0">
                                        <TextBlock FontSize="11" Foreground="#333">
                                            <Run Text="■ " Foreground="#50C878" FontWeight="Bold"/>
                                            <Run Text="Yeşil = Aynı"/>
                                        </TextBlock>
                                    </Border>
                                    <Border Background="#FFB4B4" CornerRadius="3" Padding="8,4" Margin="0,0,15,0">
                                        <TextBlock FontSize="11" Foreground="#333">
                                            <Run Text="■ " Foreground="#FF6B6B" FontWeight="Bold"/>
                                            <Run Text="Kırmızı = Farklı"/>
                                        </TextBlock>
                                    </Border>
                                    <Border Background="#FFFFC8" CornerRadius="3" Padding="8,4">
                                        <TextBlock FontSize="11" Foreground="#333">
                                            <Run Text="■ " Foreground="#FFD700" FontWeight="Bold"/>
                                            <Run Text="Sarı = Fazla Olan"/>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </StackPanel>

                            <!-- Progress Bar -->
                            <StackPanel Grid.Row="4" Margin="0,0,0,10" Visibility="Collapsed" x:Name="progressPanelCompare">
                                <ProgressBar x:Name="progressBarCompare" Height="25" Margin="0,0,0,5"/>
                                <TextBlock x:Name="txtProgressCompare" Text="Hesaplanıyor..." HorizontalAlignment="Center" 
                                   FontSize="12" Foreground="#666"/>
                            </StackPanel>

                            <!-- Results List -->
                            <Border Grid.Row="4" BorderBrush="#DDD" BorderThickness="1" 
                            Background="White" CornerRadius="5" Padding="10" x:Name="borderCompareResults">
                                <DataGrid x:Name="dgCompareResults" AutoGenerateColumns="False" 
                                  IsReadOnly="True" GridLinesVisibility="All" 
                                  HeadersVisibility="Column" CanUserResizeColumns="True"
                                  CanUserSortColumns="True" SelectionMode="Single"
                                  LoadingRow="DgCompareResults_LoadingRow"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  FrozenColumnCount="1"
                                  EnableColumnVirtualization="True"
                                  EnableRowVirtualization="True"
                                  Loaded="DgCompareResults_Loaded"
                                  SizeChanged="DgCompareResults_SizeChanged">
                                    <DataGrid.Resources>
                                        <Style TargetType="ScrollBar" BasedOn="{StaticResource DataGridScrollBarStyle}"/>
                                    </DataGrid.Resources>
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Sıra" Binding="{Binding RowNumber}" Width="60" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="Dosya Adı" Binding="{Binding FileName}" Width="200">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextWrapping" Value="Wrap"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Uzantı" Binding="{Binding FileExtension}" Width="80"/>
                                        <DataGridTemplateColumn Header="MD5 Hash" Width="200" x:Name="colCompareMD5">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock TextWrapping="Wrap">
                                                        <TextBlock.Text>
                                                            <MultiBinding>
                                                                <MultiBinding.Converter>
                                                                    <local:HashComparisonConverter/>
                                                                </MultiBinding.Converter>
                                                                <Binding Path="MD5Hash"/>
                                                                <Binding Path="SecondMD5Hash"/>
                                                                <Binding Path="FileSize"/>
                                                                <Binding Path="SecondFileSize"/>
                                                                <Binding Path="IsDifferent"/>
                                                                <Binding Path="IsFolder"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="SHA1 Hash" Width="200" x:Name="colCompareSHA1">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock TextWrapping="Wrap">
                                                        <TextBlock.Text>
                                                            <MultiBinding>
                                                                <MultiBinding.Converter>
                                                                    <local:HashComparisonConverter/>
                                                                </MultiBinding.Converter>
                                                                <Binding Path="SHA1Hash"/>
                                                                <Binding Path="SecondSHA1Hash"/>
                                                                <Binding Path="FileSize"/>
                                                                <Binding Path="SecondFileSize"/>
                                                                <Binding Path="IsDifferent"/>
                                                                <Binding Path="IsFolder"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="SHA256 Hash" Width="250" x:Name="colCompareSHA256">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock TextWrapping="Wrap">
                                                        <TextBlock.Text>
                                                            <MultiBinding>
                                                                <MultiBinding.Converter>
                                                                    <local:HashComparisonConverter/>
                                                                </MultiBinding.Converter>
                                                                <Binding Path="SHA256Hash"/>
                                                                <Binding Path="SecondSHA256Hash"/>
                                                                <Binding Path="FileSize"/>
                                                                <Binding Path="SecondFileSize"/>
                                                                <Binding Path="IsDifferent"/>
                                                                <Binding Path="IsFolder"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="SHA384 Hash" Width="250" x:Name="colCompareSHA384">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock TextWrapping="Wrap">
                                                        <TextBlock.Text>
                                                            <MultiBinding>
                                                                <MultiBinding.Converter>
                                                                    <local:HashComparisonConverter/>
                                                                </MultiBinding.Converter>
                                                                <Binding Path="SHA384Hash"/>
                                                                <Binding Path="SecondSHA384Hash"/>
                                                                <Binding Path="FileSize"/>
                                                                <Binding Path="SecondFileSize"/>
                                                                <Binding Path="IsDifferent"/>
                                                                <Binding Path="IsFolder"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="SHA512 Hash" Width="250" x:Name="colCompareSHA512">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock TextWrapping="Wrap">
                                                        <TextBlock.Text>
                                                            <MultiBinding>
                                                                <MultiBinding.Converter>
                                                                    <local:HashComparisonConverter/>
                                                                </MultiBinding.Converter>
                                                                <Binding Path="SHA512Hash"/>
                                                                <Binding Path="SecondSHA512Hash"/>
                                                                <Binding Path="FileSize"/>
                                                                <Binding Path="SecondFileSize"/>
                                                                <Binding Path="IsDifferent"/>
                                                                <Binding Path="IsFolder"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Tarih" Binding="{Binding HashDate, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" Width="150"/>
                                        <DataGridTextColumn Header="Durum" Binding="{Binding ComparisonStatus}" Width="100"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>

                            <!-- Status Text -->
                            <TextBlock Grid.Row="5" x:Name="txtStatusCompare" Margin="0,10,0,0" 
                               FontStyle="Italic" Foreground="#666"/>
                        </Grid>
                    </TabItem>
        </TabControl>
        
        <!-- Overlay - İşlem sırasında tüm ekranı kaplar -->
        <Border Grid.Row="0" Grid.RowSpan="3" x:Name="overlayBorder" 
                Background="#80000000" Visibility="Collapsed" 
                Panel.ZIndex="1000">
            <Grid>
                <Border Background="White" CornerRadius="10" Padding="30" 
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        MinWidth="300" MinHeight="150">
                    <StackPanel>
                        <TextBlock x:Name="overlayTitle" Text="İşlem Yapılıyor..." 
                                   FontSize="18" FontWeight="Bold" 
                                   Foreground="#333" 
                                   HorizontalAlignment="Center" 
                                   Margin="0,0,0,20"/>
                        <ProgressBar x:Name="overlayProgressBar" 
                                     Height="25" 
                                     IsIndeterminate="True"
                                     Margin="0,0,0,15"
                                     Visibility="Visible"/>
                        <TextBlock x:Name="overlayProgressText" 
                                   Text="Hesaplanıyor..." 
                                   FontSize="13" 
                                   Foreground="#666" 
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,15"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,0">
                            <Button x:Name="overlayCancelButton" 
                                    Width="120" 
                                    Height="38"
                                    Background="#FF5252" 
                                    Foreground="White"
                                    FontWeight="Bold"
                                    FontSize="13"
                                    Cursor="Hand"
                                    Margin="0,0,10,0"
                                    Visibility="Collapsed"
                                    Click="OverlayCancelButton_Click"
                                    BorderThickness="0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="✕" FontSize="16" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="İptal" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="{TemplateBinding Background}" 
                                                            CornerRadius="6" 
                                                            Padding="12,8">
                                                        <ContentPresenter HorizontalAlignment="Center" 
                                                                        VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#E53935"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#C62828"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button x:Name="overlayOkButton" 
                                    Content="Tamam" 
                                    Width="100" 
                                    Height="35"
                                    Background="#4A90E2" 
                                    Foreground="White"
                                    FontWeight="SemiBold"
                                    FontSize="14"
                                    Cursor="Hand"
                                    HorizontalAlignment="Center"
                                    Visibility="Collapsed"
                                    Click="OverlayOkButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        
        <!-- Footer - Sabit, her zaman görünür -->
        <Border Grid.Row="2" x:Name="footerBorder" Background="#F5F5F5" CornerRadius="0" Padding="20,15" BorderThickness="0,2,0,0" BorderBrush="#4A90E2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Progress Bar (Dosya ve klasör hash hesaplamada görünür) -->
                <StackPanel x:Name="progressPanelFileHash" Grid.Column="0" Visibility="Collapsed" VerticalAlignment="Center">
                    <ProgressBar x:Name="progressBarFileHash" Height="30" Margin="0,0,0,8"
                                 Style="{StaticResource {x:Type ProgressBar}}" 
                                 IsIndeterminate="False" Minimum="0" Maximum="100" Value="0">
                        <ProgressBar.Background>
                            <SolidColorBrush Color="#E0E0E0"/>
                        </ProgressBar.Background>
                        <ProgressBar.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#50C878" Offset="0"/>
                                <GradientStop Color="#4CAF50" Offset="1"/>
                            </LinearGradientBrush>
                        </ProgressBar.Foreground>
                    </ProgressBar>
                    <TextBlock x:Name="txtProgressFileHash" Text="Hesaplanıyor..." 
                               HorizontalAlignment="Left" FontSize="13" Foreground="#333" 
                               FontWeight="SemiBold" Margin="0,0,0,0"/>
                </StackPanel>

                <!-- Normal Durum -->
                <TextBlock x:Name="txtFooter" Grid.Column="0" Text="Hazır" 
                           HorizontalAlignment="Left" FontSize="13" Foreground="#666" 
                           VerticalAlignment="Center" FontWeight="Normal"/>

                <!-- Status Text (Klasör hash hesaplamada görünür) -->
                <TextBlock x:Name="txtStatus" Grid.Column="1" Text="" 
                           VerticalAlignment="Center" FontSize="12" Foreground="#666" 
                           FontStyle="Italic" Margin="15,0,0,0"/>

                <!-- Koraygunes yazısı -->
                <TextBlock Grid.Column="2" Text="koraygunes" 
                           VerticalAlignment="Center" FontSize="12" Foreground="#444" 
                           Opacity="0.3" Margin="15,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
